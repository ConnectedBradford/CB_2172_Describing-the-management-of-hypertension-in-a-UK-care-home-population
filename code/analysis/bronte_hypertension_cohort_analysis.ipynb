   ]
  },
  {
   "cell_type": "markdown",
   "id": "2e59beaf-a041-41e8-a419-7c258a792749",
   "metadata": {
    "tags": []
   },
   "source": [
    "run paired t test analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e18f72c0-c278-47ba-aac5-824e17c1b3f7",
