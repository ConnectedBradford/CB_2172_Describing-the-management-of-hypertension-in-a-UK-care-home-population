    "tags": []
   },
   "outputs": [],
   "source": [
    "bp_present_filtered_2 <- bp_present_filtered %>% filter(eol_measurement == \"false\") \n",
    "\n",
    "bp_present_filtered_2 %>% nrow()\n",
    "\n",
    "t.test(bp_present_filtered_2$pre_admission_systolic_value, bp_present_filtered_2$systolic_value, paired = TRUE)"
